{
  "expo": {
    "name": "Oreblogda",
    "slug": "oreblogda",
    "version": "1.9.9",
    "orientation": "default",
    "icon": "./assets/images/myicon.png",
    "scheme": "oreblogda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaytee.oreblogda",
      "associatedDomains": [
        "applinks:oreblogda.com"
      ]
    },
    "notification": {
      "icon": "./assets/images/notification.png",
      "color": "#E6F4FE"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/myicon.png",
        "backgroundImage": "./assets/images/myicon.png"
      },
      "package": "com.kaytee.oreblogda",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "oreblogda.com"
            },
            {
              "scheme": "http",
              "host": "oreblogda.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "oreblogda"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/myicon.png"
    },
    "plugins": [
      "./withPurchases.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/myicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/myicon.png",
            "backgroundColor": "#050505"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "minSdkVersion": 24,
            "launchMode": "singleTop",
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6b7afd1-028a-425e-a84e-6a2af706a736"
      }
    },
    "runtimeVersion": "v3_global",
    "updates": {
      "url": "https://u.exe.dev/b6b7afd1-028a-425e-a84e-6a2af706a736",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "owner": "oreblogda"
  }
}
